{
  "manifest_version": 3,
  "name": "SmartShield",
  "version": "1.0",
  "description": "Phishing Detection Extension",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "SmartShield"
  }
}